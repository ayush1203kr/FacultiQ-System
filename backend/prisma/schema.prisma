generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  password  String
  role      Role          @default(FACULTY)
  faculty   Faculty?
  logs      ActivityLog[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Department {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String    @unique
  description String?
  faculty     Faculty[]
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([deletedAt])
}

model Faculty {
  id              String        @id @default(cuid())
  employeeId      String        @unique
  userId          String?       @unique
  user            User?         @relation(fields: [userId], references: [id])
  firstName       String
  lastName        String
  email           String        @unique
  phone           String
  designation     String
  qualification   Qualification
  experienceYears Int           @default(0)
  subjects        String[]
  bio             String?
  departmentId    String
  department      Department    @relation(fields: [departmentId], references: [id])
  joiningDate     DateTime
  status          Status        @default(ACTIVE)
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([departmentId])
  @@index([status])
  @@index([qualification])
  @@index([deletedAt])
}

model ActivityLog {
  id        String    @id @default(cuid())
  actorId   String
  actor     User      @relation(fields: [actorId], references: [id])
  action    LogAction
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime  @default(now())

  @@index([entity, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model Counter {
  id    String @id
  value Int    @default(0)
}

enum Role {
  ADMIN
  FACULTY
}

enum Status {
  ACTIVE
  ON_LEAVE
  INACTIVE
}

enum Qualification {
  BTECH
  MTECH
  MSC
  PHD
  MBA
  OTHER
}

enum LogAction {
  CREATE
  UPDATE
  DELETE
}